[
  {
    "name": "vote callback still answered with E2T2 active",
    "setup": {
      "kv": [
        {
          "key": "poll:poll_abc",
          "value": "{\"id\":\"poll_abc\",\"chat_id\":1,\"message_id\":1001,\"creator_user_id\":1,\"question\":\"Test?\",\"is_anonymous\":true,\"is_closed\":false,\"created_at\":\"2024-01-01T00:00:00Z\",\"closed_at\":null}"
        },
        {
          "key": "opt:poll_abc_opt_0",
          "value": "{\"id\":\"poll_abc_opt_0\",\"poll_id\":\"poll_abc\",\"text\":\"A\",\"position\":0}"
        }
      ],
      "sets": [
        {
          "key": "opt:poll:poll_abc",
          "members": ["poll_abc_opt_0"]
        }
      ]
    },
    "steps": [
      {
        "send": { "callback": "vote:opt:poll_abc:0", "messageId": 1001 },
        "expect": [
          { "method": "answerCallbackQuery", "payload": { "text": "Vote recorded!" } }
        ]
      }
    ]
  },
  {
    "name": "vote change callback still answered with E2T2 active",
    "setup": {
      "kv": [
        {
          "key": "poll:poll_def",
          "value": "{\"id\":\"poll_def\",\"chat_id\":1,\"message_id\":1001,\"creator_user_id\":1,\"question\":\"Test?\",\"is_anonymous\":true,\"is_closed\":false,\"created_at\":\"2024-01-01T00:00:00Z\",\"closed_at\":null}"
        },
        {
          "key": "opt:poll_def_opt_0",
          "value": "{\"id\":\"poll_def_opt_0\",\"poll_id\":\"poll_def\",\"text\":\"A\",\"position\":0}"
        },
        {
          "key": "opt:poll_def_opt_1",
          "value": "{\"id\":\"poll_def_opt_1\",\"poll_id\":\"poll_def\",\"text\":\"B\",\"position\":1}"
        }
      ],
      "sets": [
        {
          "key": "opt:poll:poll_def",
          "members": ["poll_def_opt_0", "poll_def_opt_1"]
        }
      ]
    },
    "steps": [
      {
        "send": { "callback": "vote:opt:poll_def:1", "messageId": 1002 },
        "expect": [
          { "method": "answerCallbackQuery", "payload": { "text": "Vote recorded!" } }
        ]
      }
    ]
  },
  {
    "name": "poll_answer does not crash with E2T2 active",
