[
  {
    "name": "/csvcheck anonymous with valid CSV passes validation",
    "steps": [
      {
        "send": { "text": "/csvcheck anonymous" },
        "expect": [
          { "method": "sendMessage", "payload": { "text": "Send the CSV to validate (expected format: Option,Votes):" } }
        ]
      },
      {
        "send": { "text": "Option,Votes\nRed,2\nGreen,1\nBlue,0" },
        "expect": [
          { "method": "sendMessage", "payload": { "text": "CSV format is valid for anonymous poll." } }
        ]
      }
    ]
  },
  {
    "name": "/csvcheck public with valid CSV passes validation",
    "steps": [
      {
        "send": { "text": "/csvcheck public" },
        "expect": [
          { "method": "sendMessage", "payload": { "text": "Send the CSV to validate (expected format: Option,Votes,Voter):" } }
        ]
      },
      {
        "send": { "text": "Option,Votes,Voter\nRed,1,123\nGreen,1,456" },
        "expect": [
          { "method": "sendMessage", "payload": { "text": "CSV format is valid for public poll." } }
        ]
      }
    ]
  },
