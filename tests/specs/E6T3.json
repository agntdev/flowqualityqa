[
  {
    "name": "cast a vote via callback",
    "setup": {
      "kv": [
        {
          "key": "opt:poll_test_opt_0",
          "value": "{\"id\":\"poll_test_opt_0\",\"poll_id\":\"poll_test\",\"text\":\"A\",\"position\":0}"
        }
      ],
      "sets": [
        {
          "key": "opt:poll:poll_test",
          "members": ["poll_test_opt_0"]
        }
      ]
    },
    "steps": [
      {
        "send": { "callback": "vote:opt:poll_test:0", "messageId": 100 },
        "expect": [
          { "method": "answerCallbackQuery", "payload": { "text": "Vote recorded!" } }
        ]
      }
    ]
  },
  {
    "name": "duplicate vote via same callback",
    "setup": {
      "kv": [
        {
          "key": "opt:poll_dup_opt_0",
          "value": "{\"id\":\"poll_dup_opt_0\",\"poll_id\":\"poll_dup\",\"text\":\"A\",\"position\":0}"
        }
      ],
      "sets": [
        {
          "key": "opt:poll:poll_dup",
          "members": ["poll_dup_opt_0"]
        }
      ]
    },
    "steps": [
      {
        "send": { "callback": "vote:opt:poll_dup:0", "messageId": 101 },
        "expect": [
          { "method": "answerCallbackQuery", "payload": { "text": "Vote recorded!" } }
        ]
      },
      {
        "send": { "callback": "vote:opt:poll_dup:0", "messageId": 102 },
        "expect": [
          { "method": "answerCallbackQuery", "payload": { "text": "Vote recorded!" } }
        ]
      }
    ]
  },
  {
    "name": "change vote via different callback",
    "setup": {
      "kv": [
        {
          "key": "opt:poll_chg_opt_0",
          "value": "{\"id\":\"poll_chg_opt_0\",\"poll_id\":\"poll_chg\",\"text\":\"A\",\"position\":0}"
        },
        {
          "key": "opt:poll_chg_opt_1",
          "value": "{\"id\":\"poll_chg_opt_1\",\"poll_id\":\"poll_chg\",\"text\":\"B\",\"position\":1}"
        }
      ],
      "sets": [
        {
          "key": "opt:poll:poll_chg",
          "members": ["poll_chg_opt_0", "poll_chg_opt_1"]
        }
      ]
    },
    "steps": [
      {
        "send": { "callback": "vote:opt:poll_chg:0", "messageId": 103 },
        "expect": [
          { "method": "answerCallbackQuery", "payload": { "text": "Vote recorded!" } }
        ]
      },
      {
        "send": { "callback": "vote:opt:poll_chg:1", "messageId": 104 },
        "expect": [
          { "method": "answerCallbackQuery", "payload": { "text": "Vote recorded!" } }
        ]
      }
    ]
  },
  {
    "name": "/votestatus without poll id shows usage",
    "steps": [
      {
        "send": { "text": "/votestatus" },
        "expect": [
          { "method": "sendMessage", "payload": { "text": "Usage: /votestatus <poll_id>" } }
        ]
      }
    ]
  },
  {
    "name": "/votestatus with nonexistent poll id",
    "steps": [
      {
        "send": { "text": "/votestatus nonexistent" },
        "expect": [
          { "method": "sendMessage", "payload": { "text": "Poll not found. Check the poll ID and try again." } }
        ]
      }
    ]
  }
]