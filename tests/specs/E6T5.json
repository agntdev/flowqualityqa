      "kv": [
        { "key": "poll:poll_E6T5_closed", "value": "{\"id\":\"poll_E6T5_closed\",\"chat_id\":1,\"message_id\":2001,\"creator_user_id\":1,\"question\":\"Best color?\",\"is_anonymous\":true,\"is_closed\":false,\"created_at\":\"2025-01-01T00:00:00Z\",\"closed_at\":null}" },
        { "key": "opt:opt_E6T5_closed_a", "value": "{\"id\":\"opt_E6T5_closed_a\",\"poll_id\":\"poll_E6T5_closed\",\"text\":\"Red\",\"position\":0}" },
        { "key": "opt:opt_E6T5_closed_b", "value": "{\"id\":\"opt_E6T5_closed_b\",\"poll_id\":\"poll_E6T5_closed\",\"text\":\"Blue\",\"position\":1}" },
        { "key": "opt:opt_E6T5_closed_c", "value": "{\"id\":\"opt_E6T5_closed_c\",\"poll_id\":\"poll_E6T5_closed\",\"text\":\"Green\",\"position\":2}" },
