        { "key": "vote:vote_E6T5_closed_1", "value": "{\"id\":\"vote_E6T5_closed_1\",\"poll_id\":\"poll_E6T5_closed\",\"user_id\":3,\"option_id\":\"opt_E6T5_closed_a\",\"created_at\":\"2025-01-01T00:00:00Z\"}" },
        { "key": "vote:vote_E6T5_closed_2", "value": "{\"id\":\"vote_E6T5_closed_2\",\"poll_id\":\"poll_E6T5_closed\",\"user_id\":4,\"option_id\":\"opt_E6T5_closed_b\",\"created_at\":\"2025-01-01T00:00:00Z\"}" },
        { "key": "vote:vote_E6T5_closed_3", "value": "{\"id\":\"vote_E6T5_closed_3\",\"poll_id\":\"poll_E6T5_closed\",\"user_id\":5,\"option_id\":\"opt_E6T5_closed_c\",\"created_at\":\"2025-01-01T00:00:00Z\"}" }
      ],
      "sets": [
        { "key": "opt:poll:poll_E6T5_closed", "members": ["opt_E6T5_closed_a", "opt_E6T5_closed_b", "opt_E6T5_closed_c"] },
        { "key": "vote:poll:poll_E6T5_closed", "members": ["vote_E6T5_closed_0", "vote_E6T5_closed_1", "vote_E6T5_closed_2", "vote_E6T5_closed_3"] }
      ]
    },
    "steps": [
      {
        "send": { "callback": "poll:close:1:2001:poll_E6T5_closed", "messageId": 2000 },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "stopPoll", "payload": { "chat_id": 1, "message_id": 2001 } },
          {
            "method": "editMessageText",
            "payload": {
              "text": "✅ Poll closed.",
              "reply_markup": {
                "inline_keyboard": [
                  [{ "text": "📊 Results", "callback_data": "poll:results:poll_E6T5_closed" }],
                  [{ "text": "Export", "callback_data": "poll:export:poll_E6T5_closed" }]
                ]
              }
            }
          }
        ]
      },
      {
        "send": { "callback": "poll:results:poll_E6T5_closed", "messageId": 2000 },
        "expect": [
          { "method": "answerCallbackQuery" },
          {
            "method": "editMessageText",
            "payload": {
              "text": "<b>📊 Results</b>\n\n<b>Question:</b> Best color?\n\nRed: 2 votes (50%)\n<code>█████</code>\nBlue: 1 vote (25%)\n<code>███</code>\nGreen: 1 vote (25%)\n<code>███</code>\n\nTotal votes: 4",
              "parse_mode": "HTML",
              "reply_markup": { "inline_keyboard": [] }
            }
          }
        ]
      }
    ]
