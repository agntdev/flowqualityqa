[
  {
    "name": "post poll from preview",
    "steps": [
      {
        "send": { "callback": "menu:poll", "messageId": 1001 },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "editMessageText", "payload": { "text": "Enter a poll question:" } }
        ]
      },
      {
        "send": { "text": "Q?" },
        "expect": [
          { "method": "sendMessage", "payload": { "text": "Question set. Now send the poll options." } }
        ]
      },
      {
        "send": { "text": "show" },
        "expect": [
          { "method": "sendMessage" }
        ]
      },
      {
        "send": { "callback": "option:add", "messageId": 1003 },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "editMessageText", "payload": { "text": "Enter option 1:" } }
        ]
      },
      {
        "send": { "text": "A" },
        "expect": [
          { "method": "editMessageText" }
        ]
      },
      {
        "send": { "callback": "option:add", "messageId": 1003 },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "editMessageText", "payload": { "text": "Enter option 2:" } }
        ]
      },
      {
        "send": { "text": "B" },
        "expect": [
          { "method": "editMessageText" }
        ]
      },
      {
        "send": { "callback": "option:done", "messageId": 1003 },
        "expect": [
          { "method": "answerCallbackQuery" },
          {
            "method": "editMessageText",
            "payload": {
              "text": "<b>\u{1F4CB} Poll Preview</b>\n\n<b>Question:</b> Q?\n<b>Type:</b> Anonymous\n\n<b>Options:</b>\n  1. A\n  2. B\n"
            }
          }
        ]
      },
      {
        "send": { "callback": "poll:post", "messageId": 1003 },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "sendPoll", "payload": { "question": "Q?", "options": [{ "text": "A" }, { "text": "B" }] } },
          {
            "method": "editMessageText",
            "payload": {
              "text": "\u2705 Poll posted!",
              "reply_markup": {
                "inline_keyboard": [
                  [{ "text": "Close poll", "callback_data": "poll:close:1:1014:poll_1_1014" }],
                  [{ "text": "Export", "callback_data": "poll:export:poll_1_1014" }]
                ]
              }
            }
          }
        ]
      }
    ]
  },
