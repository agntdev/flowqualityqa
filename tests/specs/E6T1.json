[
  {
    "name": "create poll with 3 options and anonymous toggle",
    "steps": [
      {
        "send": { "callback": "menu:poll", "messageId": 1001 },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "editMessageText", "payload": { "text": "Enter a poll question:" } }
        ]
      },
      {
        "send": { "text": "Favorite colors?" },
        "expect": [
          { "method": "sendMessage", "payload": { "text": "Question set. Now send the poll options." } }
        ]
      },
      {
        "send": { "text": "show" },
        "expect": [
          { "method": "sendMessage" }
        ]
      },
      {
        "send": { "callback": "option:add", "messageId": 1003 },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "editMessageText", "payload": { "text": "Enter option 1:" } }
        ]
      },
      {
        "send": { "text": "Red" },
        "expect": [
          { "method": "editMessageText" }
        ]
      },
      {
        "send": { "callback": "option:add", "messageId": 1003 },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "editMessageText", "payload": { "text": "Enter option 2:" } }
        ]
      },
      {
        "send": { "text": "Green" },
        "expect": [
          { "method": "editMessageText" }
        ]
      },
      {
        "send": { "callback": "option:add", "messageId": 1003 },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "editMessageText", "payload": { "text": "Enter option 3:" } }
        ]
      },
      {
        "send": { "text": "Blue" },
        "expect": [
          { "method": "editMessageText" }
        ]
      },
      {
        "send": { "callback": "option:done", "messageId": 1003 },
        "expect": [
          { "method": "answerCallbackQuery" },
          {
            "method": "editMessageText",
            "payload": {
              "text": "<b>\u{1F4CB} Poll Preview</b>\n\n<b>Question:</b> Favorite colors?\n<b>Type:</b> Anonymous\n\n<b>Options:</b>\n  1. Red\n  2. Green\n  3. Blue\n"
            }
          }
        ]
      },
      {
        "send": { "callback": "poll:anon", "messageId": 1003 },
        "expect": [
          { "method": "answerCallbackQuery" },
          {
            "method": "editMessageText",
            "payload": {
              "text": "<b>\u{1F4CB} Poll Preview</b>\n\n<b>Question:</b> Favorite colors?\n<b>Type:</b> Public\n\n<b>Options:</b>\n  1. Red\n  2. Green\n  3. Blue\n",
              "reply_markup": {
                "inline_keyboard": [
                  [{ "text": "\u{1F4E4} Post poll", "callback_data": "poll:post" }],
                  [{ "text": "\u270F\uFE0F Edit options", "callback_data": "poll:edit" }],
                  [{ "text": "\u{1F464} Anonymous: OFF", "callback_data": "poll:anon" }],
                  [{ "text": "Cancel", "callback_data": "poll:cancel" }]
                ]
              }
            }
          }
        ]
      },
      {
        "send": { "callback": "poll:post", "messageId": 1003 },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "sendPoll", "payload": { "question": "Favorite colors?", "options": [{ "text": "Red" }, { "text": "Green" }, { "text": "Blue" }] } },
          { "method": "editMessageText", "payload": { "text": "\u2705 Poll posted!" } }
        ]
      }
    ]
  }
]
